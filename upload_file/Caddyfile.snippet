# upload.develle.fr — WebDAV inbox for phone → server file drops.
# Mirrors share.develle.fr's TLS setup: DNS-01 via Cloudflare, port 443 only.
# Single user, basic auth over HTTPS, bcrypt hash inline.
# Pull files off the Pi with `pull-uploads` on TheBeast.
#
# `webdav` is a third-party directive with no default order, so the WebDAV
# handler and the catch-all `respond 404` live inside an explicit `route`
# block that fixes their execution order.

upload.develle.fr {
	root * /srv/upload

	# Single account: "louis" with the bcrypt hash from `caddy hash-password`.
	# Hash is safe to commit (bcrypt) but rotating the password means
	# rotating this line + the saved cred on every device.
	basic_auth /* {
		louis $2a$14$76HvtCpFtvKEUbZeHgGgbOFk6VTGrEaDPicyXQj4J73Yb6nnCMJnm
	}

	route {
		# Browsers that navigate to /inbox/ (a footgun, since /inbox is the
		# WebDAV path) get redirected to the upload UI. Only GET/HEAD —
		# real WebDAV verbs (PUT, PROPFIND, DELETE, MKCOL, etc.) still
		# reach the webdav handler below.
		@browser_inbox {
			method GET HEAD
			path /inbox /inbox/
		}
		redir @browser_inbox / 302

		# WebDAV inbox at /inbox/* (used by the UI's PUT requests and by
		# any native WebDAV client that may also connect here).
		webdav /inbox/* {
			prefix /inbox
			root /srv/upload/inbox
		}

		# Everything else: serve the static upload UI. file_server returns
		# 404 for unknown paths and auto-serves /srv/upload/ui/index.html
		# at the root.
		root * /srv/upload/ui
		file_server
	}

	log {
		output file /var/log/caddy/upload.access.log
	}
}
